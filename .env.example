DEBUG=0
# Genera una clave fuerte: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Con DEBUG=0 el arranque ABORTA si dejas el valor de ejemplo.
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.example
CSRF_TRUSTED_ORIGINS=https://your-domain.example
DATABASE_URL=postgres://notisnotis:notisnotis@db:5432/notisnotis
TIME_ZONE=Europe/Madrid

# Credenciales de Postgres para docker compose (db). En PROD cambia la contraseña
# y refléjala también en DATABASE_URL.
POSTGRES_DB=notisnotis
POSTGRES_USER=notisnotis
POSTGRES_PASSWORD=notisnotis

# Seguridad / HTTPS (la app va detrás de un reverse proxy que termina TLS).
# Con DEBUG=0 las cookies ya son Secure y se fuerza redirección a HTTPS.
# Activa HSTS SOLO cuando el dominio sirva siempre por HTTPS (empieza con un valor
# bajo, p.ej. 3600, y súbelo a 31536000 cuando lo confirmes).
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=0
SECURE_HSTS_PRELOAD=0
# Cookies Secure (solo HTTPS). Por defecto 1 con DEBUG=0. Pon 0 si TAMBIÉN entras por
# http en la LAN (si no, al recargar perderías la sesión y te pediría login de nuevo).
COOKIE_SECURE=1

# Nivel de log a stdout: DEBUG|INFO|WARNING|ERROR
LOG_LEVEL=INFO

# Almacenamiento de media en S3 / compatible (opcional). Si defines el bucket, los
# ficheros subidos se guardan en S3; si lo dejas vacío, se usa el disco local.
# Para MinIO/R2/Spaces, rellena AWS_S3_ENDPOINT_URL con su endpoint.
AWS_STORAGE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
AWS_DEFAULT_ACL=
AWS_S3_QUERYSTRING_AUTH=1
AWS_S3_FILE_OVERWRITE=0
# Servir también los estáticos desde S3 (en vez de whitenoise). Requiere collectstatic.
AWS_S3_STATIC=0

# IA — chat (resúmenes, sesgo, enriquecimiento): mock|openrouter|openai|ollama|ollama_cloud
AI_DEFAULT_PROVIDER=mock
AI_DEFAULT_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com/api/chat

# IA — OpenAI (chat + embeddings) y Jina (embeddings). Si dejas las claves vacías, cada
# usuario las configura en Ajustes → Análisis con IA (patrón de cascada). base_url de
# OpenAI sirve también para gateways compatibles (Azure/LocalAI/vLLM).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
JINA_API_KEY=
JINA_BASE_URL=https://api.jina.ai/v1

# IA — transcripción de podcasts/YouTube (fuentes audio). Cascada como chat/embeddings.
# whisper_local usa el servicio Whisper del stack; openai usa la API (whisper-1).
AI_TRANSCRIBE_PROVIDER=whisper_local
AI_TRANSCRIBE_MODEL=
AI_TRANSCRIBE_LANG=
WHISPER_URL=http://whisper:9000
# Modelo del contenedor Whisper local (tiny|base|small|medium|large-v3). Más grande = mejor y más lento.
ASR_MODEL=base

# IA — embeddings: mock|openai|jina|ollama|ollama_cloud (OpenRouter NO da embeddings)
AI_EMBED_PROVIDER=mock
# Modelos recomendados: openai → text-embedding-3-small; jina → jina-embeddings-v3;
# ollama → nomic-embed-text.
AI_EMBED_MODEL=nomic-embed-text
# Dimensión de los vectores. OpenAI (text-embedding-3-*) y Jina v3 aceptan `dimensions`,
# así que se recortan a este valor y encajan en la columna pgvector. La columna se declara
# con esta dimensión (def. 256): si la cambias, regenera la migración del campo
# embedding_vec (ver articles/models.py). Modelos sin dimensión variable deben usar su
# dimensión nativa aquí.
AI_EMBED_DIM=256

# Comportamiento de IA
AI_ENRICH_MODE=on_demand          # batch|on_demand
AI_CLUSTER_THRESHOLD=0.78
AI_CLUSTER_WINDOW_DAYS=3
AI_TIMEOUT=120

# RSS
RSS_USER_AGENT=NotisNotis/0.1

# Feeds con IA: buscador web. Por defecto el SearXNG del propio stack (servicio searxng).
SEARCH_URL=http://searxng:8080
SEARCH_LANG=es
# Secreto de SearXNG (genera uno: openssl rand -hex 32)
SEARXNG_SECRET=change-me-searxng-secret

# Texto completo / muros de pago (off por defecto; respeta copyright/ToS)
FULLTEXT_ENABLED=0

# Scheduler (segundos entre pasadas del pipeline)
PIPELINE_INTERVAL=900

# Servidor MCP (token de un usuario; genéralo en Ajustes → Tokens)
NOTISNOTIS_API_TOKEN=

# Funciones / tiers (sistema de feature flags; ver docs/FEATURES.md)
# Dormido por defecto: con 0, TODAS las funciones están activas para todos.
# Ponlo a 1 para aplicar tiers/beta/overrides por usuario (Admin → User entitlements).
FEATURES_ENFORCED=0
FEATURES_DEFAULT_TIER=free
FEATURES_DISABLED=

# Módulos/sectores (ver docs/MODULES.md). Activan/desactivan sectores ENTEROS por cascada
# (este .env del operador manda; si lo dejas sin fijar, cada usuario lo decide en Ajustes).
# Perfiles: curation=0 podcasts=0 → lector RSS simple con IA; curation=0 podcasts=1 → RSS +
# podcasts; ambos =1 → todo. Por defecto (sin fijar) los tres sectores están activos.
MODULE_CURATION=1
MODULE_PODCASTS=1

# API gpodder (sincronización de podcasts con AntennaPod). 0 para desactivarla.
GPODDER_ENABLED=1

# ---------------------------------------------------------------------------
# PATRÓN DE CONFIGURACIÓN EN CASCADA (vale para TODAS las opciones de abajo y
# para las API keys de arriba). Para cada opción:
#   1) si la defines aquí (valor no vacío) → GLOBAL: la usan todos los usuarios y
#      no pueden cambiarla (aparece como solo lectura en Ajustes);
#   2) si la dejas vacía → cada usuario la configura en sus Ajustes (solo para él);
#   3) si nadie la define → se usa el valor por defecto.
# Las funciones con FLAG (p.ej. DIGEST_ENABLED) además se activan/desactivan aquí.
# ---------------------------------------------------------------------------

# Digest por email — FLAG de activación (true/false)
DIGEST_ENABLED=0
# SMTP del digest (cascada): si lo rellenas aquí → digest global para todos;
# si DIGEST_ENABLED=1 pero dejas el SMTP vacío → cada usuario pone su propio SMTP en Ajustes.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=1

# Web Push — FLAG + claves VAPID (genera con: vapid --gen, o web-push generate-vapid-keys)
WEBPUSH_ENABLED=0
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=
